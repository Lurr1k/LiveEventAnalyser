# Copy this file to `.env` and fill in local secrets.
# Never commit `.env`.

# Required for ElevenLabs realtime stage transcription.
ELEVENLABS_API_KEY=

# Required only when LLM analysis should call OpenAI instead of neutral fallback.
OPENAI_API_KEY=

# Optional runtime defaults. The current backend uses these values if unset.
ELEVENLABS_MODEL_ID=scribe_v2_realtime
ELEVENLABS_LANGUAGE_CODE=en
ELEVENLABS_SAMPLE_RATE=16000

# Optional Streamlit server settings.
STREAMLIT_SERVER_PORT=8501
